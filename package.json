{
  "name": "prompt-gym",
  "displayName": "Prompt Gym",
  "description": "Draft, token-count, and optimize prompts before sending to Copilot, ChatGPT, or Claude — offline, no API key needed.",
  "version": "0.9.0",
  "publisher": "devkraft",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/AnushreeSRalph/prompt-gym"
  },
  "bugs": {
    "url": "https://github.com/AnushreeSRalph/prompt-gym/issues"
  },
  "homepage": "https://github.com/AnushreeSRalph/prompt-gym#readme",
  "license": "MIT",
  "keywords": [
    "token",
    "tokenizer",
    "prompt",
    "llm",
    "ai",
    "gpt",
    "claude",
    "copilot",
    "gemini",
    "optimization",
    "token counter",
    "prompt engineering"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:promptGym.open",
    "onCommand:promptGym.copyOptimized",
    "onCommand:promptGym.optimizeSelection"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "prompt-gym-container",
          "title": "Prompt Gym",
          "icon": "media/icon-activity.svg"
        }
      ]
    },
    "views": {
      "prompt-gym-container": [
        {
          "type": "webview",
          "id": "promptGym.mainView",
          "name": "Prompt Gym"
        }
      ]
    },
    "commands": [
      {
        "command": "promptGym.open",
        "title": "Prompt Gym: Open Rehearsal Space",
        "icon": "$(beaker)"
      },
      {
        "command": "promptGym.copyOptimized",
        "title": "Prompt Gym: Copy Optimized Prompt"
      },
      {
        "command": "promptGym.optimizeSelection",
        "title": "Prompt Gym: Optimize Selection"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "promptGym.open"
        },
        {
          "command": "promptGym.copyOptimized"
        },
        {
          "command": "promptGym.optimizeSelection"
        }
      ],
      "editor/context": [
        {
          "command": "promptGym.optimizeSelection",
          "group": "9_cutcopypaste@10",
          "when": "editorHasSelection"
        }
      ]
    },
    "configuration": {
      "title": "Prompt Gym",
      "properties": {
        "promptGym.tokenizerModel": {
          "type": "string",
          "default": "o200k_base",
          "enum": [
            "o200k_base",
            "cl100k_base"
          ],
          "enumDescriptions": [
            "GPT-4o family (o200k_base). Also used for Copilot.",
            "GPT-4 / GPT-3.5 family (cl100k_base). Used as approximation for Claude and Gemini."
          ],
          "description": "Tokenizer encoding used when no model is selected in the panel. The panel's model selector overrides this."
        },
        "promptGym.tokenWarningThreshold": {
          "type": "number",
          "default": 2000,
          "minimum": 100,
          "description": "Show a threshold warning flag when the prompt exceeds this many tokens."
        },
        "promptGym.pastedCodeTokenThreshold": {
          "type": "number",
          "default": 300,
          "minimum": 50,
          "description": "Flag a fenced code block as oversized when it exceeds this many tokens. Reduce to catch smaller pastes."
        },
        "promptGym.semanticRedundancyThreshold": {
          "type": "number",
          "default": 0.5,
          "minimum": 0.3,
          "maximum": 0.9,
          "description": "Jaccard similarity threshold (0–1) for semantic redundancy detection between sentences. Lower = more sensitive; higher = only flag near-identical sentences."
        },
        "promptGym.structuralRepeatThreshold": {
          "type": "number",
          "default": 0.45,
          "minimum": 0.3,
          "maximum": 0.9,
          "description": "Jaccard similarity threshold (0–1) for flagging a closing paragraph that repeats the opening."
        },
        "promptGym.monthlyTokenBudget": {
          "type": "number",
          "default": 400000,
          "minimum": 1000,
          "description": "Monthly token budget shown in the context bar. Tracks cumulative tokens copied this month."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.config.js",
    "watch": "node esbuild.config.js --watch",
    "test": "node test-runner.mjs",
    "typecheck": "tsc --noEmit",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^2.32.0",
    "esbuild": "^0.23.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "gpt-tokenizer": "^2.2.0"
  }
}